{
    "name": "ahmed3bead/laravel-tenant-audit",
    "description": "Multi-tenant audit logging for Laravel applications",
    "keywords": ["laravel", "tenant", "audit", "multi-tenant", "logging"],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Ahmed Abead",
            "email": "ahmed@ahmed3bead.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/database": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^10.0|^11.0|^12.0",
        "pestphp/pest": "^2.0|^3.0",
        "pestphp/pest-plugin-laravel": "^2.0|^3.0",
        "laravel/pint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Ahmed3bead\\TenantAudit\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Ahmed3bead\\TenantAudit\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ahmed3bead\\TenantAudit\\TenantAuditServiceProvider"
            ],
            "aliases": {
                "TenantAudit": "Ahmed3bead\\TenantAudit\\Facades\\TenantAudit"
            }
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test:coverage": "vendor/bin/pest --coverage --min=80",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "pestphp/pest": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
